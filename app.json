{
  "expo": {
    "name": "Miam Miam",
    "slug": "miam-miam",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D3040"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D3040"
      },
      "package": "com.miammiam.app",
      "permissions": ["CAMERA"]
    },
    "extra": {
      "eas": {
        "projectId": "62d37fdc-e313-494f-aa56-bcbf1146d4ba"
      }
    },
    "owner": "mckeller1277",
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Miam Miam utilise la caméra pour scanner les codes-barres."
        }
      ]
    ]
  }
}
